{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Scene 1 Local Server",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\serve.ps1",
        "-Port",
        "5500"
      ],
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Scene 1 Local Server (Python Direct)",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "http.server",
        "5500"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
